apiVersion: kubeagents.x-k8s.io/v1alpha1
kind: OperatorAgent
metadata:
  name: operator-agent-${TARGET_CLUSTER_NAME}-${TARGET_CLUSTER_LOCATION}
  namespace: kubeagents-system
spec:
  harness:
    clusterName: "${TARGET_CLUSTER_NAME}"
    location: "${TARGET_CLUSTER_LOCATION}"
    projectId: "${PROJECT_ID}"
    hermes:
      apiServerSecretRef:
        name: "platform-agent-secrets"
        key: "API_SERVER_KEY"
  deployment:
    image: "${OPERATOR_AGENT_IMAGE}"
    tag: "latest"
  security:
    serviceAccountName: "${TARGET_OP_KSA}"
    serviceAccountAnnotations:
      iam.gke.io/gcp-service-account: "${TARGET_OP_GSA}@${PROJECT_ID}.iam.gserviceaccount.com"
    remoteIdentitySubject: "${TARGET_OP_GSA}@${PROJECT_ID}.iam.gserviceaccount.com"
