apiVersion: kubeagents.x-k8s.io/v1alpha1
kind: DevTeamAgent
metadata:
  name: devteam-agent-${TARGET_CLUSTER_NAME}-${TARGET_CLUSTER_LOCATION}-${TARGET_NAMESPACE}
  namespace: kubeagents-system
spec:
  harness:
    clusterName: "${TARGET_CLUSTER_NAME}"
    location: "${TARGET_CLUSTER_LOCATION}"
    projectId: "${PROJECT_ID}"
    namespace: "${TARGET_NAMESPACE}"
    hermes:
      apiServerSecretRef:
        name: "platform-agent-secrets"
        key: "API_SERVER_KEY"
  deployment:
    image: "${DEVTEAM_AGENT_IMAGE}"
    tag: "latest"
  security:
    serviceAccountName: "${TARGET_DT_KSA}"
    serviceAccountAnnotations:
      iam.gke.io/gcp-service-account: "${TARGET_DT_GSA}@${PROJECT_ID}.iam.gserviceaccount.com"
    remoteIdentitySubject: "${TARGET_DT_GSA}@${PROJECT_ID}.iam.gserviceaccount.com"
